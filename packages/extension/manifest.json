{
  "manifest_version": 3,
  "name": "XEgineer",
  "version": "0.1.0",
  "description": "多平台内容发布工具",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://10.135.224.249/*",
    "https://*.zhihu.com/*",
    "https://*.bilibili.com/*",
    "https://*.juejin.cn/*",
    "https://mp.weixin.qq.com/*",
    "https://*.weixin.qq.com/*",
    "https://*.weibo.com/*",
    "https://*.csdn.net/*",
    "https://*.csdnimg.cn/*",
    "https://*.huaweicloud.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.jianshu.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "http://10.135.224.249/*"],
      "js": ["src/bridge/content-script.ts"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "XEgineer"
  }
}
